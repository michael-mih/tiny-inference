<?xml version="1.0"?>
<robot name="tiny_panda" xmlns:xacro="http://www.ros.org/wiki/xacro">
  <xacro:arg name="controllers_file" default="$(find tiny_inference_ros)/config/panda_gazebo_controllers.yaml"/>

  <xacro:property name="pi" value="3.141592653589793"/>

  <xacro:macro name="simple_inertial" params="mass ixx iyy izz">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="${mass}"/>
      <inertia ixx="${ixx}" ixy="0" ixz="0" iyy="${iyy}" iyz="0" izz="${izz}"/>
    </inertial>
  </xacro:macro>

  <xacro:macro name="box_link" params="name size color mass">
    <link name="${name}">
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <box size="${size}"/>
        </geometry>
        <material name="${name}_mat">
          <color rgba="${color}"/>
        </material>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <box size="${size}"/>
        </geometry>
      </collision>
      <xacro:simple_inertial mass="${mass}" ixx="0.02" iyy="0.02" izz="0.02"/>
    </link>
  </xacro:macro>

  <xacro:macro name="cylinder_link" params="name radius length color mass">
    <link name="${name}">
      <visual>
        <origin xyz="0 0 0" rpy="0 ${pi / 2.0} 0"/>
        <geometry>
          <cylinder radius="${radius}" length="${length}"/>
        </geometry>
        <material name="${name}_mat">
          <color rgba="${color}"/>
        </material>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="0 ${pi / 2.0} 0"/>
        <geometry>
          <cylinder radius="${radius}" length="${length}"/>
        </geometry>
      </collision>
      <xacro:simple_inertial mass="${mass}" ixx="0.03" iyy="0.03" izz="0.03"/>
    </link>
  </xacro:macro>

  <link name="world"/>

  <link name="panda_link0">
    <visual>
      <origin xyz="0 0 0.10" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.16" length="0.20"/>
      </geometry>
      <material name="panda_dark">
        <color rgba="0.08 0.08 0.09 1"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0.10" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.16" length="0.20"/>
      </geometry>
    </collision>
    <xacro:simple_inertial mass="4.0" ixx="0.08" iyy="0.08" izz="0.08"/>
  </link>

  <joint name="world_to_panda_base" type="fixed">
    <parent link="world"/>
    <child link="panda_link0"/>
    <origin xyz="0 0 0.02" rpy="0 0 0"/>
  </joint>

  <xacro:cylinder_link name="panda_link1" radius="0.055" length="0.34" color="0.85 0.86 0.84 1" mass="2.0"/>
  <xacro:cylinder_link name="panda_link2" radius="0.050" length="0.30" color="0.18 0.18 0.19 1" mass="2.0"/>
  <xacro:cylinder_link name="panda_link3" radius="0.048" length="0.32" color="0.85 0.86 0.84 1" mass="1.6"/>
  <xacro:cylinder_link name="panda_link4" radius="0.044" length="0.28" color="0.18 0.18 0.19 1" mass="1.4"/>
  <xacro:cylinder_link name="panda_link5" radius="0.040" length="0.24" color="0.85 0.86 0.84 1" mass="1.2"/>
  <xacro:cylinder_link name="panda_link6" radius="0.036" length="0.18" color="0.18 0.18 0.19 1" mass="1.0"/>
  <xacro:cylinder_link name="panda_link7" radius="0.034" length="0.16" color="0.85 0.86 0.84 1" mass="0.8"/>
  <xacro:box_link name="panda_hand" size="0.16 0.10 0.08" color="0.12 0.12 0.13 1" mass="0.6"/>
  <xacro:box_link name="panda_leftfinger" size="0.025 0.025 0.10" color="0.10 0.10 0.11 1" mass="0.1"/>
  <xacro:box_link name="panda_rightfinger" size="0.025 0.025 0.10" color="0.10 0.10 0.11 1" mass="0.1"/>

  <joint name="panda_joint1" type="revolute">
    <parent link="panda_link0"/>
    <child link="panda_link1"/>
    <origin xyz="0 0 0.25" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-2.8973" upper="2.8973" effort="80" velocity="2.0"/>
    <dynamics damping="1.0" friction="0.2"/>
  </joint>

  <joint name="panda_joint2" type="revolute">
    <parent link="panda_link1"/>
    <child link="panda_link2"/>
    <origin xyz="0 0 0.18" rpy="0 ${pi / 2.0} 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-1.7628" upper="1.7628" effort="80" velocity="2.0"/>
    <dynamics damping="1.0" friction="0.2"/>
  </joint>

  <joint name="panda_joint3" type="revolute">
    <parent link="panda_link2"/>
    <child link="panda_link3"/>
    <origin xyz="0.30 0 0" rpy="0 ${-pi / 2.0} 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-2.8973" upper="2.8973" effort="80" velocity="2.0"/>
    <dynamics damping="1.0" friction="0.2"/>
  </joint>

  <joint name="panda_joint4" type="revolute">
    <parent link="panda_link3"/>
    <child link="panda_link4"/>
    <origin xyz="0.28 0 0" rpy="0 ${-pi / 2.0} 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.0718" upper="-0.0698" effort="80" velocity="2.0"/>
    <dynamics damping="1.0" friction="0.2"/>
  </joint>

  <joint name="panda_joint5" type="revolute">
    <parent link="panda_link4"/>
    <child link="panda_link5"/>
    <origin xyz="0.25 0 0" rpy="0 ${pi / 2.0} 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-2.8973" upper="2.8973" effort="20" velocity="2.5"/>
    <dynamics damping="0.6" friction="0.1"/>
  </joint>

  <joint name="panda_joint6" type="revolute">
    <parent link="panda_link5"/>
    <child link="panda_link6"/>
    <origin xyz="0.20 0 0" rpy="0 ${-pi / 2.0} 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-0.0175" upper="3.7525" effort="20" velocity="2.5"/>
    <dynamics damping="0.6" friction="0.1"/>
  </joint>

  <joint name="panda_joint7" type="revolute">
    <parent link="panda_link6"/>
    <child link="panda_link7"/>
    <origin xyz="0.16 0 0" rpy="0 ${pi / 2.0} 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-2.8973" upper="2.8973" effort="20" velocity="2.5"/>
    <dynamics damping="0.4" friction="0.1"/>
  </joint>

  <joint name="panda_hand_joint" type="fixed">
    <parent link="panda_link7"/>
    <child link="panda_hand"/>
    <origin xyz="0.12 0 0" rpy="0 0 0"/>
  </joint>

  <joint name="panda_finger_joint1" type="prismatic">
    <parent link="panda_hand"/>
    <child link="panda_leftfinger"/>
    <origin xyz="0.06 0.025 -0.06" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="0.0" upper="0.04" effort="10" velocity="0.2"/>
    <dynamics damping="0.2" friction="0.05"/>
  </joint>

  <joint name="panda_finger_joint2" type="prismatic">
    <parent link="panda_hand"/>
    <child link="panda_rightfinger"/>
    <origin xyz="0.06 -0.025 -0.06" rpy="0 0 0"/>
    <axis xyz="0 -1 0"/>
    <limit lower="0.0" upper="0.04" effort="10" velocity="0.2"/>
    <dynamics damping="0.2" friction="0.05"/>
  </joint>

  <ros2_control name="GazeboSimSystem" type="system">
    <hardware>
      <plugin>gz_ros2_control/GazeboSimSystem</plugin>
    </hardware>

    <joint name="panda_joint1">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="panda_joint2">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="panda_joint3">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="panda_joint4">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="panda_joint5">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="panda_joint6">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="panda_joint7">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="panda_finger_joint1">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="panda_finger_joint2">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
  </ros2_control>

  <gazebo>
    <plugin filename="libgz_ros2_control-system.so" name="gz_ros2_control::GazeboSimROS2ControlPlugin">
      <parameters>$(arg controllers_file)</parameters>
    </plugin>
  </gazebo>
</robot>
